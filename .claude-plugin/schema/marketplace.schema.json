{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Marketplace Manifest",
  "description": "plugins[*] の name/version/description は各 {plugin}/.claude-plugin/plugin.json と byte-identical である必要がある",
  "type": "object",
  "required": ["name", "description", "owner", "plugins"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": { "name": { "type": "string" } }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "version", "author", "source"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "description": { "type": "string" },
          "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "author": {
            "type": "object",
            "required": ["name"],
            "properties": { "name": { "type": "string" } }
          },
          "source": {
            "type": "string",
            "pattern": "^\\./[a-z][a-z0-9-]*$"
          }
        }
      }
    }
  }
}
